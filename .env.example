# Django
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (for Docker, these are set in docker-compose.yml)
# DATABASE_URL=postgres://postgres:postgres@db:5432/library

# Redis (for Docker, these are set in docker-compose.yml)
# REDIS_URL=redis://redis:6379/0

# AI (Gemini) - optional, for weekly challenges
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# S3 Storage (optional)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=

# CORS
CORS_ALLOWED_ORIGINS=
